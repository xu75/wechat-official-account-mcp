# Wechat Publisher Agent local config (DO NOT COMMIT real values)

# Agent HTTP base URL (for request script)
AGENT_BASE_URL=http://127.0.0.1:4273

# Shared HMAC secret between ECS and local agent
WECHAT_AGENT_SIGNING_SECRET=replace-with-your-hmac-secret

# Review approval token verification (assist mode guard)
WECHAT_AGENT_REQUIRE_REVIEW_TOKEN=true
# If empty, fallback to WECHAT_AGENT_SIGNING_SECRET
WECHAT_AGENT_REVIEW_TOKEN_SECRET=
WECHAT_AGENT_REVIEW_TOKEN_ISSUER=ecs-review
WECHAT_AGENT_REVIEW_TOKEN_TTL_SECONDS=600
WECHAT_AGENT_REVIEWER=reviewer

# Local server listen port
PORT=4273

# Optional: browser fallback switch (Phase B keep false)
WECHAT_AGENT_ENABLE_BROWSER_FALLBACK=false

# Browser publish mode: manual | command
WECHAT_AGENT_BROWSER_PUBLISH_MODE=manual

# When mode=command, agent executes this command with one arg: payload json path
# Example: WECHAT_AGENT_BROWSER_PUBLISH_CMD="node /absolute/path/to/your-browser-publisher.mjs"
# Local mock example:
# WECHAT_AGENT_BROWSER_PUBLISH_CMD="node /Users/xujinsong/VSCode/SynologyDrive/wechat-official-account-mcp/scripts/browser-publisher/mock-success.mjs"
WECHAT_AGENT_BROWSER_PUBLISH_CMD=

# Browser command timeout in milliseconds
WECHAT_AGENT_BROWSER_COMMAND_TIMEOUT_MS=180000

# Manual mode task output directory
WECHAT_AGENT_MANUAL_TASK_DIR=/tmp/wechat-agent-manual-tasks

# Optional: local log path
WECHAT_AGENT_LOG_FILE=/tmp/wechat-agent.log
