# Browser command mode example (local only)
AGENT_BASE_URL=http://127.0.0.1:4273
WECHAT_AGENT_SIGNING_SECRET=replace-with-your-hmac-secret
PORT=4273

# Review approval token verification (assist mode guard)
WECHAT_AGENT_REQUIRE_REVIEW_TOKEN=true
WECHAT_AGENT_REVIEW_TOKEN_SECRET=
WECHAT_AGENT_REVIEW_TOKEN_ISSUER=ecs-review
WECHAT_AGENT_REVIEW_TOKEN_TTL_SECONDS=600
WECHAT_AGENT_REVIEWER=reviewer

# Browser settings
WECHAT_AGENT_ENABLE_BROWSER_FALLBACK=true
WECHAT_AGENT_BROWSER_PUBLISH_MODE=command
WECHAT_AGENT_BROWSER_PUBLISH_CMD=node /Users/xujinsong/VSCode/SynologyDrive/wechat-official-account-mcp/scripts/browser-publisher/playwright-cdp-wechat-publish.mjs
WECHAT_AGENT_BROWSER_COMMAND_TIMEOUT_MS=600000
WECHAT_AGENT_LOGIN_SESSION_TTL_MS=600000
WECHAT_BROWSER_CHANNEL=chrome
WECHAT_BROWSER_HEADLESS=false
WECHAT_BROWSER_SUBMIT_MODE=draft
WECHAT_BROWSER_USER_DATA_DIR=~/.wechat-agent/pw-profile
WECHAT_BROWSER_CDP_PORT=9222
WECHAT_BROWSER_CDP_URL=http://127.0.0.1:9222
WECHAT_BROWSER_CDP_START_TIMEOUT_MS=30000
WECHAT_BROWSER_LOGIN_TIMEOUT_MS=600000
WECHAT_BROWSER_PUBLISH_LOGIN_TIMEOUT_MS=30000
WECHAT_BROWSER_RETURN_LOGIN_QR=true
WECHAT_BROWSER_ACTION_TIMEOUT_MS=30000
WECHAT_BROWSER_NAV_TIMEOUT_MS=60000
WECHAT_BROWSER_DEBUG_DIR=/tmp/wechat-agent-browser-debug
WECHAT_BROWSER_DRY_RUN=false
WECHAT_BROWSER_LOGIN_STABLE_ROUNDS=1
WECHAT_BROWSER_VERBOSE=false

WECHAT_AGENT_MANUAL_TASK_DIR=/tmp/wechat-agent-manual-tasks
WECHAT_AGENT_LOG_FILE=/tmp/wechat-agent.log
